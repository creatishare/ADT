# =============================================================================
# Agent Designer V2 — 环境变量示例
# =============================================================================
# 复制此文件为 .env.local，按需填入对应供应商的 API Key。
# 只需要配置你在界面上会切换到的模型，未配置的模型在被选中时会返回友好错误提示。
#
# 详细配置说明参见 docs/MODELS.md
# =============================================================================


# ---------- Google Gemini (gemini-3.1) ---------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSy-your-gemini-key-goes-here"
# 可选：走兼容代理时填入
# GOOGLE_GENERATIVE_AI_BASE_URL="https://your-proxy.example.com/v1beta"
# 可选：覆盖实际调用的模型名（默认 "gemini-2.5-flash"，可改为 "gemini-3.1-pro-preview" 等）
# GOOGLE_GENERATIVE_AI_MODEL="gemini-2.5-flash"


# ---------- OpenAI (gpt-5.2) -------------------------------------------------
# OPENAI_API_KEY="sk-your-openai-key"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-5.2"


# ---------- Moonshot / Kimi (kimi-k2.5) --------------------------------------
# MOONSHOT_API_KEY="sk-your-moonshot-key"
# MOONSHOT_BASE_URL="https://api.moonshot.cn/v1"
# MOONSHOT_MODEL="kimi-k2.5"


# ---------- DeepSeek (deepseek-v3.2) -----------------------------------------
# DEEPSEEK_API_KEY="sk-your-deepseek-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
# DEEPSEEK_MODEL="deepseek-chat"


# ---------- Doubao / 字节火山引擎 (doubao-seed-2.0-pro) ----------------------
# DOUBAO_API_KEY="your-volcano-ark-api-key"
# DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# DOUBAO_MODEL="doubao-seed-2.0-pro"


# ---------- 记忆提取子调用（可选） -------------------------------------------
# 当历史消息超过 MAX_RECENT_MESSAGES (=8) 时，服务端会额外跑一次 generateObject
# 把历史压成分层记忆。默认复用主 ModelId；设置下面这个可路由到更便宜/更快的模型，
# 仅对这次子调用生效，不影响 Orchestrator 与其它 4 个子 Agent。
# 值必须是 AVAILABLE_MODELS 里已知的 ModelId，未命中或初始化失败时安全回退主模型。
# MEMORY_MODEL_ID="deepseek-v3.2"


# ---------- 开发调试 ---------------------------------------------------------
# CHAT_DEBUG=1         # 在服务端打印详细流日志
# E2E_TEST_MODE=1      # 启用 E2E mock 模式（不会真实调用模型）
