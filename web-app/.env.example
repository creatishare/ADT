# =============================================================================
# Agent Designer V2 — 环境变量示例
# =============================================================================
# 复制此文件为 .env.local，填入公司 AI 网关的 API Key 即可。
# 项目所有模型都统一走公司中转网关（hetao gateway），不再分供应商配置。
#
# 详细配置说明参见 docs/MODELS.md
# =============================================================================


# ---------- 公司 AI 网关（必填） ---------------------------------------------
# 由公司统一签发的 AI Gateway，OpenAI 兼容协议，承载所有模型调用。
#
# 一把 Key（最简单）：
HETAO_GATEWAY_API_KEY="your-hetao-gateway-key"
#
# 多把 Key 用英文逗号分隔，服务端会按轮询 (round-robin) 分发，
# 多人并发时能线性扩展 RPM/TPM 上限：
# HETAO_GATEWAY_API_KEYS="key-1,key-2,key-3"
#
# 复数与单数同时存在时，单数 Key 会被忽略。
#
# 可选：网关 Base URL（如果公司变更网关地址再填）
# HETAO_GATEWAY_BASE_URL="https://ai-gateway.corp.hetao101.com"


# ---------- 各 UI 模型对应的上游模型别名（可选覆盖） -------------------------
# 默认的 UI 模型 ID → 上游模型名映射（无需配置即生效）：
#   deepseek-v4-flash       →  ali.public.deepseek-v4-flash
#   deepseek-v4-flash-free  →  ht.local.deepseek-v4-flash
#   deepseek-v4-pro         →  ali.public.deepseek-v4-pro
#   qwen3.6-flash           →  qwen3.6-flash
#   gpt-5.4-mini            →  gpt-5.4-mini
#   gpt-5.5                 →  gpt-5.5
#
# 如需切换某个 UI 模型对应的上游别名（例如网关上线了新版本），通过下面的
# HETAO_MODEL_<UI_ID> 环境变量覆盖。命名规则：UI ID 转大写，所有非字母数字
# 字符替换为下划线。
# HETAO_MODEL_DEEPSEEK_V4_FLASH="ali.public.deepseek-v4-flash-2026q2"
# HETAO_MODEL_DEEPSEEK_V4_FLASH_FREE="ht.local.deepseek-v4-flash-v2"
# HETAO_MODEL_DEEPSEEK_V4_PRO="ali.public.deepseek-v4-pro-2026q2"
# HETAO_MODEL_QWEN3_6_FLASH="qwen3.7-flash"
# HETAO_MODEL_GPT_5_4_MINI="gpt-5.4-mini-2026q2"
# HETAO_MODEL_GPT_5_5="gpt-5.5-2026q2"


# ---------- LLM 并发限流（可选，默认关闭） -----------------------------------
# 默认行为：**不限制**（pass-through）。
# 公司网关已在网关侧做了限流，客户端再加一层会让"Orchestrator 流持有 slot →
# 子 Agent 拿不到 slot"自死锁（一个对话同时占用 1 个 Orchestrator + 最多 4 个子
# Agent 的并发名额），从而拖慢甚至卡住高并发场景。详见 src/lib/llm/gate.ts。
#
# 仅当你确实想在客户端兜底限流时（例如离开公司网关、自建反向代理无限流），
# 才启用下面的变量。启用时请确保
#   容量 ≥ 同时在线用户数 × (1 + 子 Agent 数)
# 否则会重新出现排队/死锁。
#
# 直接指定 hetao 网关的并发上限（优先级最高）
# LLM_CONCURRENCY_HETAO=20
#
# 或：「每把 Key 容量 × Key 池大小 = 总容量」公式
# LLM_PER_KEY_CONCURRENCY=5


# ---------- 记忆提取子调用（可选） -------------------------------------------
# 当历史消息超过 MAX_RECENT_MESSAGES (=8) 时，服务端会额外跑一次 generateObject
# 把历史压成分层记忆。默认复用主 ModelId；设置下面这个可路由到更便宜/更快的模型，
# 仅对这次子调用生效，不影响 Orchestrator 与其它 4 个子 Agent。
# 值必须是 AVAILABLE_MODELS 里已知的 ModelId，未命中或初始化失败时安全回退主模型。
# MEMORY_MODEL_ID="deepseek-v4-flash"


# ---------- 子 Agent 流式调用（可选） ----------------------------------------
# 开启后子 Agent 工具调用走流式 + 逐 chunk 空闲超时（chunkMs），替代默认的
# 整体墙钟超时（generateText timeout）。适合在长 prompt 下首 token 慢、但持
# 续吐字稳定的场景：只要模型在持续返回内容就不会 abort。
#
#   未设置 / =0：走 generateText + 60s/120s 墙钟（兼容默认）
#   =1       ：走 streamText + 40s/60s 空闲 + 90s/180s 总预算上限 + 单次 idle 重试
#
# 建议先在测试环境开启观察 1-2 天，再切到生产默认。
# SUB_AGENT_USE_STREAMING=1


# ---------- 开发调试 ---------------------------------------------------------
# CHAT_DEBUG=1         # 在服务端打印详细流日志
# E2E_TEST_MODE=1      # 启用 E2E mock 模式（不会真实调用模型）
